# ============================================
# ADMIN CHRONO - Variables d'Environnement
# ============================================
# Copiez ce fichier vers .env.local et remplissez les valeurs

# ============================================
# SUPABASE
# ============================================
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Optionnel : URL publique (override de https://admin.kro-no-delivery.com dans lib/siteUrl.ts).
# Si absent, le build utilise quand même le bon domaine pour og:image (plus de *.vercel.app).
NEXT_PUBLIC_SITE_URL=https://admin.kro-no-delivery.com

# ============================================
# API BACKEND
# ============================================
# LOCAL : Next.js tourne sur ta machine → souvent http://localhost:4000 vers chrono_backend local.
# VERCEL : les vraies URLs prod (https://… Render) se configurent dans Vercel → Settings → Environment Variables,
# pas dans ce fichier (ce .env.local.example sert au dev).
NEXT_PUBLIC_API_URL=https://api.yourdomain.com

# URL du serveur WebSocket (peut être la même que l'API)
NEXT_PUBLIC_SOCKET_URL=https://api.yourdomain.com

# Origine du navigateur en dev (ex. http://192.168.1.66:3000) — auto par `npm run predev` / set-local-ip.js
# Utilisez votre IP LAN réelle, pas http://0.0.0.0:3000 (0.0.0.0 sert seulement au bind du serveur).
NEXT_PUBLIC_DEV_ORIGIN=http://localhost:3000

# IP pour l’affichage « URL réseau » au démarrage (auto : npm run predev / set-local-ip.js)
LAN_DEV_HOST=192.168.1.1

# ============================================
# MAPBOX (remplace Google Maps)
# ============================================
# Token d'accès Mapbox pour les cartes (https://account.mapbox.com/access-tokens/)
NEXT_PUBLIC_MAPBOX_ACCESS_TOKEN=pk.your-mapbox-access-token

# Optionnel — icône livreur sur /track (PNG/SVG HTTPS ou chemin /public, ex. /assets/track-driver.png)
# Sans cette variable : défaut = public/assets/track-driver-marker.svg (voir docs/checklists/track-map-driver-png.md)
# NEXT_PUBLIC_TRACK_DRIVER_ICON_URL=
