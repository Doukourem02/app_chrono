# Copier vers .env et remplir les valeurs.

NODE_ENV=production
PORT=4000

JWT_SECRET=your-super-secret-jwt-key-minimum-32-characters-long
# Optionnel : durée du refresh JWT (syntaxe jsonwebtoken). Défaut ~10 ans — « rester connecté » jusqu’à déconnexion app.
# JWT_REFRESH_EXPIRES_IN=3650d

# Signature HMAC des QR de livraison (min. 32 caractères en prod). Même valeur si plusieurs instances backend.
QR_CODE_SECRET=change-me-in-production-minimum-32-characters-long-secret-key
FORCE_HTTPS=true
PROXY_ENABLED=true

DATABASE_URL=postgresql://user:password@host:5432/dbname
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

ALLOWED_ORIGINS=https://admin.yourdomain.com,https://app.yourdomain.com,https://driver.yourdomain.com

# URL publique de la page de suivi /track (même origine que l’admin Next déployé). Utilisée dans les SMS Twilio au destinataire sans compte.
# Ne pas mettre localhost — sur téléphone le lien serait invalide.
# PUBLIC_TRACK_BASE_URL=https://admin.yourdomain.com

# URL publique du backend (sans chemin). Requis si les apps mobiles envoient Origin=https://api… sur Socket.IO (sinon CORS 400 / polling).
# Sur Render, RENDER_EXTERNAL_URL est souvent défini automatiquement ; sinon définir explicitement :
# API_PUBLIC_URL=https://api.yourdomain.com

# Optionnel : si absent, le backend logue seulement (voir server.ts).
SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL
LOG_LEVEL=info

# Logs centralisés (Better Stack / Logtail) — en prod, avec la source token du dashboard.
# BETTER_STACK_SOURCE_TOKEN=...
# Alias accepté : LOGTAIL_SOURCE_TOKEN

# Durée de validité du code OTP (minutes). Défaut 5 ; plage 2–10 (aligné SMS / email / stockage).
# OTP_TTL_MINUTES=5
#
# Si les logs indiquent relation "otp_codes" does not exist :
#   npm run migrate:otp

# Twilio : SMS (otpMethod sms) et WhatsApp (otpMethod whatsapp) — même SID + token
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your-auth-token
TWILIO_SMS_FROM=+33612345678
# TWILIO_SMS_MESSAGING_SERVICE_SID=MGxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# TWILIO_SMS_BODY_BRAND=Chrono
TWILIO_WHATSAPP_FROM=whatsapp:+12603466204
# TWILIO_WHATSAPP_MESSAGING_SERVICE_SID=
# TWILIO_WHATSAPP_CONTENT_SID=
# TWILIO_WHATSAPP_CONTENT_VARIABLES_JSON={"2":"5"}
# TWILIO_WHATSAPP_BODY_BRAND=Krono

# Web Push (page suivi public /track/: token) — générer avec : npx web-push generate-vapid-keys
# Table SQL : npm run migrate:track-web-push
# WEB_PUSH_PUBLIC_KEY=BM...
# WEB_PUSH_PRIVATE_KEY=...
# WEB_PUSH_SUBJECT=mailto:support@votredomaine.com
#
# Les clés VAPID ne remplacent pas PUBLIC_TRACK_BASE_URL (plus haut) : sans cette URL HTTPS,
# les SMS n’incluent pas de lien /track valide. L’origine de PUBLIC_TRACK_BASE_URL doit être
# dans ALLOWED_ORIGINS (CORS) pour que la page /track puisse appeler l’API (subscribe push, etc.).

# Alternative SMS si pas Twilio
VONAGE_API_KEY=your-vonage-api-key
VONAGE_API_SECRET=your-vonage-api-secret
VONAGE_FROM=YourAppName

REDIS_URL=redis://localhost:6379

SWAGGER_ENABLED=false

# Optionnel : token Expo (compte expo.dev) pour l’API push ; augmente les quotas. Sinon l’envoi anonyme fonctionne souvent pour le dev.
# EXPO_ACCESS_TOKEN=

MAPBOX_ACCESS_TOKEN=pk.your-mapbox-token
DEBUG_SOCKETS=false
# Matching livreurs : positions driver_profiles plus vieilles que X minutes sont ignorées (défaut 25)
DRIVER_DB_POSITION_MAX_AGE_MIN=25

# Pool Postgres — ajuster au plan Supabase (connexions max).
DB_POOL_MAX=20
DB_POOL_MIN=2
DB_POOL_IDLE_TIMEOUT=30000
# Délai max pour établir une connexion (ms). 2000 est trop bas en prod distante ; défaut code 25000.
DB_POOL_CONNECTION_TIMEOUT=25000
DB_QUERY_TIMEOUT=30000
# Au démarrage : essais du SELECT 1 si la DB est lente (déploiement / cold start)
# DB_POOL_VERIFY_ATTEMPTS=4
# DB_POOL_VERIFY_RETRY_DELAY_MS=3000
# Requête rôle admin (middleware) : retry si erreur réseau/timeout uniquement
# ADMIN_PG_ROLE_QUERY_ATTEMPTS=3
# ADMIN_PG_ROLE_QUERY_RETRY_MS=250
