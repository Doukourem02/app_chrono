# ============================================
# DRIVER CHRONO (Chauffeur) - Variables d'Environnement
# ============================================
# Copiez ce fichier vers .env et remplissez les valeurs
# Note: Expo utilise le préfixe EXPO_PUBLIC_ pour les variables publiques
#
# TestFlight / eas build --profile production : le .env local n'est PAS sur les serveurs EAS.
# Copiez les MÊMES valeurs dans EAS → Environment variables → "production" (eas env:list).
# Sinon l'app client peut marcher en dev et planter ou manquer carte/Supabase en prod.

# ============================================
# API BACKEND
# ============================================
# DEV LOCAL (téléphone + Mac même Wi‑Fi, backend sur le Mac) :
#   EXPO_PUBLIC_API_URL=http://192.168.1.66:4000
#   EXPO_PUBLIC_SOCKET_URL=http://192.168.1.66:4000
#   (remplace 192.168.1.66 par l’IP affichée par Expo / ton ifconfig)
#
# PROD (EAS build store / TestFlight) : https vers Render, définir aussi sur expo.dev → Secrets / env "production".
#   EXPO_PUBLIC_API_URL=https://ton-service.onrender.com
#   EXPO_PUBLIC_SOCKET_URL=https://ton-service.onrender.com
#
# Modèle ci‑dessous = prod ; en local écris dans ton .env l’URL http://192.168.x.x:4000
EXPO_PUBLIC_API_URL=https://api.yourdomain.com

# URL du serveur WebSocket (souvent identique à l’API)
EXPO_PUBLIC_SOCKET_URL=https://api.yourdomain.com

# ============================================
# SUPABASE
# ============================================
EXPO_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# ============================================
# MAPBOX
# ============================================
# Token Mapbox pour les cartes (pk.ey...)
EXPO_PUBLIC_MAPBOX_ACCESS_TOKEN=pk.your-mapbox-public-token

# OBLIGATOIRE pour EAS Build iOS (@rnmapbox/maps) : token secret Mapbox (sk.ey...), scope DOWNLOADS:READ
# Ne pas préfixer EXPO_PUBLIC_ (secret). Définir sur EAS : eas env:create → environnement preview/production → Sensitive
# Voir https://docs.mapbox.com/ios/maps/guides/install/#configure-credentials
# RNMAPBOX_MAPS_DOWNLOAD_TOKEN=sk.ey...

# ============================================
# LÉGAL (stores — §2.5 ckprod.md)
# ============================================
# Pages publiques admin_chrono (voir app/legal/*)
EXPO_PUBLIC_LEGAL_CGU_URL=https://admin.kro-no-delivery.com/legal/cgu
EXPO_PUBLIC_LEGAL_PRIVACY_URL=https://admin.kro-no-delivery.com/legal/confidentialite

# ============================================
# SENTRY (Optionnel)
# ============================================
# DSN Sentry pour le monitoring d'erreurs
EXPO_PUBLIC_SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id
