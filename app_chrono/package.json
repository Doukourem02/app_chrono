{
  "name": "app_chrono",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "scripts": {
    "update-ip": "node ./scripts/update-env-ip.js",
    "prestart": "npm run update-ip",
    "test": "jest",
    "start": "BASELINE_BROWSER_MAPPING_IGNORE_OLD_DATA=true expo start",
    "reset-project": "node ./scripts/reset-project.js",
    "android": "BASELINE_BROWSER_MAPPING_IGNORE_OLD_DATA=true expo run:android",
    "ios": "BASELINE_BROWSER_MAPPING_IGNORE_OLD_DATA=true expo run:ios",
    "web": "BASELINE_BROWSER_MAPPING_IGNORE_OLD_DATA=true expo start --web",
    "lint": "BASELINE_BROWSER_MAPPING_IGNORE_OLD_DATA=true expo lint",
    "postinstall": "patch-package"
  },
  "dependencies": {
    "@expo/ui": "~55.0.11",
    "@expo/vector-icons": "^15.0.3",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-navigation/bottom-tabs": "^7.4.0",
    "@react-navigation/elements": "^2.6.3",
    "@react-navigation/native": "^7.1.8",
    "@rnmapbox/maps": "^10.2.10",
    "@sentry/react-native": "~7.11.0",
    "@supabase/supabase-js": "^2.77.0",
    "dotenv": "~16.4.5",
    "expo": "~55.0.0",
    "expo-asset": "~55.0.15",
    "expo-audio": "~55.0.13",
    "expo-constants": "~55.0.14",
    "expo-contacts": "~55.0.13",
    "expo-dev-client": "~55.0.27",
    "expo-file-system": "~55.0.16",
    "expo-font": "~55.0.6",
    "expo-haptics": "~55.0.14",
    "expo-image": "~55.0.8",
    "expo-image-picker": "~55.0.18",
    "expo-linking": "~55.0.13",
    "expo-location": "~55.1.8",
    "expo-network": "~55.0.13",
    "expo-notifications": "~55.0.19",
    "expo-router": "~55.0.12",
    "expo-secure-store": "~55.0.13",
    "expo-splash-screen": "~55.0.18",
    "expo-status-bar": "~55.0.5",
    "expo-symbols": "~55.0.7",
    "expo-system-ui": "~55.0.15",
    "expo-task-manager": "~55.0.14",
    "expo-web-browser": "~55.0.14",
    "expo-widgets": "55.0.13",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-native": "0.83.4",
    "react-native-gesture-handler": "~2.30.0",
    "react-native-reanimated": "4.2.1",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.23.0",
    "react-native-url-polyfill": "^3.0.0",
    "react-native-web": "~0.21.0",
    "react-native-worklets": "0.7.2",
    "socket.io-client": "^4.8.1",
    "zustand": "^5.0.8"
  },
  "devDependencies": {
    "@types/jest": "^29.5.12",
    "@types/react": "~19.2.10",
    "baseline-browser-mapping": "^2.9.2",
    "eslint": "^9.25.0",
    "eslint-config-expo": "~55.0.0",
    "jest": "^29.7.0",
    "patch-package": "^8.0.1",
    "typescript": "~5.9.2"
  },
  "jest": {
    "testEnvironment": "node",
    "transform": {
      "^.+\\.[jt]sx?$": ["babel-jest", { "presets": ["babel-preset-expo"] }]
    },
    "testMatch": [
      "**/__tests__/**/*.test.ts",
      "**/__tests__/**/*.test.tsx"
    ],
    "moduleFileExtensions": ["ts", "tsx", "js", "jsx"]
  },
  "private": true,
  "engines": {
    "node": "20.x",
    "npm": "10.x"
  }
}
