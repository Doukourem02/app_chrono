+  private static func writeImageDataToSharedFile(_ data: Data, forKey key: String) -> URL? {
+    guard let groupIdentifier = WidgetsStorage.appGroupIdentifier,
+          let containerURL = FileManager.default.containerURL(forSecurityApplicationGroupIdentifier: groupIdentifier) else {
+      return nil
+    }
+
+    let directoryURL = containerURL.appendingPathComponent("LiveActivityImages", isDirectory: true)
+    try? FileManager.default.createDirectory(at: directoryURL, withIntermediateDirectories: true)
+
+    let fileURL = directoryURL.appendingPathComponent(key).appendingPathExtension("img")
+    if FileManager.default.fileExists(atPath: fileURL.path) {
+      return fileURL
+    }
+
+    do {
+      try data.write(to: fileURL, options: [.atomic])
+      return fileURL
+    } catch {
