@@ -1,7 +1,45 @@
 import Foundation
 import JavaScriptCore
 
+// Cache JSContext per layout string. expo/expo#44543 - avoid recreation on each island refresh.
+private var cachedWidgetContexts: [String: JSContext] = [:]
+
+/// Marker for `Bundle(for:)` — resources may live in the pod framework instead of `Bundle.main` in some embeds.
+private final class ExpoWidgetsResourceMarker {}
+
+/// Loads Metro output for the widget runtime (nested bundle, flat file, or framework bundle). expo/expo#43654
+private func loadExpoWidgetsJS() -> String? {
+  let bundles: [Bundle] = [Bundle.main, Bundle(for: ExpoWidgetsResourceMarker.self)]
+
+  for bundle in bundles {
+    if let outerURL = bundle.url(forResource: "ExpoWidgets", withExtension: "bundle"),
+       let outer = Bundle(url: outerURL),
+       let innerURL = outer.url(forResource: "ExpoWidgets", withExtension: "bundle"),
+       let js = try? String(contentsOf: innerURL, encoding: .utf8) {
+      return js
+    }
+  }
+
+  for bundle in bundles {
+    if let flatURL = bundle.url(forResource: "ExpoWidgets", withExtension: "bundle") {
+      var isDir: ObjCBool = false
+      if FileManager.default.fileExists(atPath: flatURL.path, isDirectory: &isDir),
+         !isDir.boolValue,
+         let js = try? String(contentsOf: flatURL, encoding: .utf8) {
+        return js
+      }
+    }
+  }
+
+  print("[ExpoWidgets] Missing ExpoWidgets.bundle (nested, flat, and framework bundle lookups failed)")
+  return nil
+}
+
 func createWidgetContext(layout: String) -> JSContext? {
+  if !layout.isEmpty, let cached = cachedWidgetContexts[layout] {
+    return cached
+  }
+
