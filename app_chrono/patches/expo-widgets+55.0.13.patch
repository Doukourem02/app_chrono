+      return (nil, nil, nil, nil)
+    }
+    let pending = root["isPending"] as? Bool == true
+    let status = stringField("statusLabel", root) ?? (pending ? "Recherche livreur" : nil)
+    return (
+      stringField("etaLabel", root),
+      stringField("vehicleInfoLabel", root) ?? stringField("vehicleLabel", root),
+      status,
+      stringField("plateLabel", root)
+    )
+  }
+
+  /// Champs additionnels pour la bannière verrouillage (photo, téléphone, heure affichée).
+  static func parseBannerExtras(_ propsJson: String) -> (phone: String?, avatar: String?, clock: String?, pending: Bool, progress: Double) {
+    guard let data = propsJson.data(using: .utf8),
+          let root = try? JSONSerialization.jsonObject(with: data) as? [String: Any] else {
