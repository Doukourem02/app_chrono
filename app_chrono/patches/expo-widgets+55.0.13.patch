+  let fwURL = Bundle.main.bundleURL.appendingPathComponent("Frameworks/ExpoWidgets.framework/ExpoWidgets.bundle")
+  var fwIsDir: ObjCBool = false
+  if FileManager.default.fileExists(atPath: fwURL.path, isDirectory: &fwIsDir),
+     !fwIsDir.boolValue,
+     let js = try? String(contentsOf: fwURL, encoding: .utf8),
+     !js.isEmpty {
