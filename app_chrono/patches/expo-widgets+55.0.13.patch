diff --git a/node_modules/expo-widgets/ios/LiveActivityAvatarCache.swift b/node_modules/expo-widgets/ios/LiveActivityAvatarCache.swift
new file mode 100644
index 0000000..c94a5a7
--- /dev/null
+++ b/node_modules/expo-widgets/ios/LiveActivityAvatarCache.swift
@@ -0,0 +1,145 @@
+import Foundation
+import UIKit
+
+enum LiveActivityAvatarCache {
+  private static let keyPrefix = "__expo_widgets_live_activity_avatar_"
+  private static let maxAvatarBytes = 1_500_000
+
+  static func enrichProps(_ props: String) -> String {
+    guard var root = parseProps(props) else {
+      return props
+    }
+
+    cacheImageField("driverAvatarUrl", into: "driverAvatarCacheKey", in: &root)
+    cacheImageField("vehicleMarkerUrl", into: "vehicleMarkerCacheKey", in: &root)
+    guard let data = try? JSONSerialization.data(withJSONObject: root),
+          let enriched = String(data: data, encoding: .utf8) else {
+      return props
+    }
+    return enriched
+  }
+
+  static func imageData(from propsJson: String) -> Data? {
+    guard let root = parseProps(propsJson) else {
+      return nil
+    }
+    if let key = stringField("driverAvatarCacheKey", root),
+       let data = WidgetsStorage.getData(forKey: key) {
+      return data
+    }
+    if let source = stringField("driverAvatarUrl", root) {
+      return WidgetsStorage.getData(forKey: cacheKey(for: source))
+    }
+    return nil
+  }
+
+  static func markerImageData(from propsJson: String) -> Data? {
+    guard let root = parseProps(propsJson) else {
+      return nil
+    }
+    if let key = stringField("vehicleMarkerCacheKey", root),
+       let data = WidgetsStorage.getData(forKey: key) {
+      return data
+    }
+    if let source = stringField("vehicleMarkerUrl", root) {
+      return WidgetsStorage.getData(forKey: cacheKey(for: source))
+    }
+    return nil
+  }
+
+  private static func parseProps(_ props: String) -> [String: Any]? {
+    guard let data = props.data(using: .utf8) else { return nil }
+    return try? JSONSerialization.jsonObject(with: data) as? [String: Any]
+  }
+
+  private static func stringField(_ key: String, _ root: [String: Any]) -> String? {
+    guard let raw = root[key] as? String else { return nil }
+    let value = raw.trimmingCharacters(in: .whitespacesAndNewlines)
+    return value.isEmpty ? nil : value
+  }
+
+  private static func cacheKey(for avatarURLString: String) -> String {
+    let encoded = Data(avatarURLString.utf8)
+      .base64EncodedString()
+      .replacingOccurrences(of: "/", with: "_")
+      .replacingOccurrences(of: "+", with: "-")
+      .replacingOccurrences(of: "=", with: "")
+    return keyPrefix + encoded
+  }
+
+  private static func cacheImageField(
+    _ sourceField: String,
+    into cacheField: String,
+    in root: inout [String: Any]
+  ) {
+    guard let source = stringField(sourceField, root) else { return }
+    let key = cacheKey(for: source)
+    if WidgetsStorage.getData(forKey: key) == nil,
+       let data = imageData(fromSource: source),
+       data.count <= maxAvatarBytes {
+      WidgetsStorage.set(data, forKey: key)
+    }
+
+    guard let data = WidgetsStorage.getData(forKey: key) else {
+      return
+    }
+
+    root[cacheField] = key
+    if let fileURL = writeImageDataToSharedFile(data, forKey: key) {
+      root[sourceField] = fileURL.absoluteString
+    }
+  }
+
+  private static func writeImageDataToSharedFile(_ data: Data, forKey key: String) -> URL? {
+    guard let groupIdentifier = WidgetsStorage.appGroupIdentifier,
+          let containerURL = FileManager.default.containerURL(forSecurityApplicationGroupIdentifier: groupIdentifier) else {
+      return nil
+    }
+
+    let directoryURL = containerURL.appendingPathComponent("LiveActivityImages", isDirectory: true)
+    try? FileManager.default.createDirectory(at: directoryURL, withIntermediateDirectories: true)
+
+    let fileURL = directoryURL.appendingPathComponent(key).appendingPathExtension("img")
+    if FileManager.default.fileExists(atPath: fileURL.path) {
+      return fileURL
+    }
+
+    do {
+      try data.write(to: fileURL, options: [.atomic])
+      return fileURL
+    } catch {
+      return nil
+    }
+  }
+
+  private static func imageData(fromSource source: String) -> Data? {
+    if source.lowercased().hasPrefix("http") {
+      return downloadAvatarData(from: source)
+    }
+    guard let url = URL(string: source) else { return nil }
+    return try? Data(contentsOf: url)
+  }
+
+  private static func downloadAvatarData(from avatarURLString: String) -> Data? {
+    guard let url = URL(string: avatarURLString) else { return nil }
+    let semaphore = DispatchSemaphore(value: 0)
+    var result: Data?
+
+    let task = URLSession.shared.dataTask(with: url) { data, response, _ in
+      defer { semaphore.signal() }
+      guard let http = response as? HTTPURLResponse,
+            (200...299).contains(http.statusCode),
+            let data else {
+        return
+      }
+      result = data
+    }
+    task.resume()
+
+    if semaphore.wait(timeout: .now() + 2.5) == .timedOut {
+      task.cancel()
+      return nil
+    }
+    return result
+  }
+}
