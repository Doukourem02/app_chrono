+    switch stringField("statusCode", root) {
+    case "accepted", "enroute":
+      return "1 min"
+    case "in_progress":
+      return "1 min"
+    case "picked_up", "delivering":
+      return "1 min"
+    case "completed":
+      return "OK"
+    default:
+      return "1 min"
+    }
+  }
+
+  static func driverInitials(_ propsJson: String) -> String {
+    guard let data = propsJson.data(using: .utf8),
+          let root = try? JSONSerialization.jsonObject(with: data) as? [String: Any] else {
