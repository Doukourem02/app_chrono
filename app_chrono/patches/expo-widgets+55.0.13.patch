+
+extension Color {
+  init?(hex: String) {
+    var hexString = hex.trimmingCharacters(in: .whitespacesAndNewlines)
+    if hexString.hasPrefix("#") {
+      hexString.removeFirst()
+    }
+    guard hexString.count == 6, let rgb = UInt64(hexString, radix: 16) else {
+      return nil
+    }
+    self.init(
