# ============================================
# APP CHRONO (Client) - Variables d'Environnement
# ============================================
# Copiez ce fichier vers .env et remplissez les valeurs
# Note: Expo utilise le préfixe EXPO_PUBLIC_ pour les variables publiques
#
# TestFlight / eas build --profile production : le .env local n'est PAS sur les serveurs EAS.
# Il faut les MÊMES clés dans EAS → Environment variables → environment "production"
# (eas env:list). Si seules API_URL et SOCKET_URL y sont, le binaire store n'a pas Supabase / Mapbox, etc.

# ============================================
# API BACKEND
# ============================================
# Tu as DEUX situations :
#
# 1) DEV LOCAL (Expo + téléphone sur le même Wi‑Fi que le Mac qui tourne chrono_backend)
#    → IP LAN du Mac, pas "localhost" (sur le téléphone localhost = le téléphone lui‑même).
#    Exemple :
#    EXPO_PUBLIC_API_URL=http://192.168.1.66:4000
#    EXPO_PUBLIC_SOCKET_URL=http://192.168.1.66:4000
#
# 2) PROD (TestFlight / App Store / build EAS "production")
#    → Ton URL Render en https, SANS IP 192.168. Ces valeurs ne viennent PAS du .env sur ton Mac
#    sauf si tu les injectes au build ; en pratique : EAS Dashboard → Environment variables → production.
#    Exemple :
#    EXPO_PUBLIC_API_URL=https://ton-service.onrender.com
#    EXPO_PUBLIC_SOCKET_URL=https://ton-service.onrender.com
#
# URL de l'API (sans / final) — ci‑dessous : modèle prod ; en local remplace par ton http://192.168.x.x:4000
EXPO_PUBLIC_API_URL=https://api.yourdomain.com

# URL du serveur WebSocket (souvent identique à l’API)
EXPO_PUBLIC_SOCKET_URL=https://api.yourdomain.com

# URL publique de l’admin Next qui sert /track/... (bouton « Partager le lien au destinataire »).
# Indépendant des clés Web Push du backend : les VAPID servent aux notifs navigateur ; cette URL
# sert à construire le lien cliquable (partage + cohérence avec PUBLIC_TRACK_BASE_URL côté serveur).
# Sans cette variable, le lien partagé reste http://localhost:3000 — invalide sur le téléphone du destinataire.
# Même valeur en EAS → Environment variables → profile « production » (https, sans / final).
# EXPO_PUBLIC_TRACK_BASE_URL=https://admin.yourdomain.com

# ============================================
# SUPABASE
# ============================================
EXPO_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# ============================================
# MAPBOX
# ============================================
# Token Mapbox pour les cartes (pk.ey...)
EXPO_PUBLIC_MAPBOX_ACCESS_TOKEN=pk.your-mapbox-public-token

# ============================================
# LÉGAL (stores — §2.5 ckprod.md)
# ============================================
# URLs HTTPS stables vers vos CGU et politique de confidentialité (site, admin Next, ou Notion public).
# Même politique que l’écran Profil > Confidentialité (document faisant foi = page web).
# En prod : pages publiques déployées avec admin_chrono (ex. Vercel)
EXPO_PUBLIC_LEGAL_CGU_URL=https://admin.kro-no-delivery.com/legal/cgu
EXPO_PUBLIC_LEGAL_PRIVACY_URL=https://admin.kro-no-delivery.com/legal/confidentialite

# ============================================
# SENTRY (recommandé pour TestFlight / prod)
# ============================================
# Crée 2 projets sur https://sentry.io (ex. "krono-client" et "krono-driver") → copie le DSN public.
# TestFlight : ajoute EXPO_PUBLIC_SENTRY_DSN dans EAS → Environment variables → production (même clé que ci-dessous).
EXPO_PUBLIC_SENTRY_DSN=https://your-key@your-org.ingest.sentry.io/your-project-id
